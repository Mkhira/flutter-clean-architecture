{
  "openapi": "3.0.1",
  "info": { "title": "Shapes Fixture API", "version": "1.0" },
  "paths": {
    "/things": {
      "get": {
        "tags": ["Things"],
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ThingDto" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BaseDto": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int32" },
          "name": { "type": "string" }
        }
      },
      "ThingDto": {
        "allOf": [
          { "$ref": "#/components/schemas/BaseDto" },
          {
            "type": "object",
            "properties": {
              "extra": { "type": "string" },
              "tags": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              },
              "note": { "type": "string", "nullable": true }
            }
          }
        ]
      }
    }
  }
}
